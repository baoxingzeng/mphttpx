{
  "name": "mphttpx",
  "version": "2.4.0",
  "license": "MIT",
  "author": "Xingzeng Bao",
  "homepage": "https://github.com/baoxingzeng/mphttpx",
  "description": "A polyfill for mini programs.",
  "type": "module",
  "main": "dist/mphttpx.cjs.js",
  "module": "dist/mphttpx.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "!dist/types/**/*",
    "!dist/cjs/types/**/*",
    "!dist/esm/types/**/*"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup --config",
    "test": "node tests/test.js"
  },
  "keywords": [
    "小程序",
    "mini-program",
    "polyfill",
    "微信",
    "WeChat",
    "Weixin",
    "TextEncoder",
    "TextDecoder",
    "Blob",
    "FormData",
    "fetch",
    "XMLHttpRequest",
    "WebSocket"
  ],
  "dependencies": {
    "fetch-xhr-shim": ">=1.0.0",
    "miniprogram-platform": ">=1.0.0",
    "miniprogram-websocket": ">=1.0.0",
    "miniprogram-xmlhttprequest-shim": ">=1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "formidable": "^3.5.4",
    "rollup": "^4.53.1",
    "rollup-plugin-dts": "^6.3.0",
    "tslib": "^2.8.1",
    "uvu": "^0.5.6",
    "ws": "^8.19.0",
    "xhr2": "^0.2.1"
  }
}